# APK Crack Engine 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================
# 调试与日志配置
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
ACE_LOG_LEVEL=INFO

# 日志目录 (默认: ~/.apk_crack_engine/logs)
ACE_LOG_DIR=~/.apk_crack_engine/logs

# 日志文件最大大小 (MB)
ACE_LOG_MAX_SIZE=10

# 日志备份数量
ACE_LOG_BACKUPS=5

# ============================================
# ADB 配置
# ============================================
# ADB 可执行文件路径 (留空使用系统 PATH)
ACE_ADB_PATH=

# ADB 默认超时 (秒)
ACE_ADB_TIMEOUT=10

# ADB 重试次数
ACE_ADB_RETRIES=3

# ============================================
# Frida 配置
# ============================================
# Frida-server 路径 (设备端)
ACE_FRIDA_SERVER_PATH=/data/local/tmp/frida-server

# Frida 默认超时 (秒)
ACE_FRIDA_TIMEOUT=30

# Frida 重试次数
ACE_FRIDA_RETRIES=3

# ============================================
# APK 工具配置
# ============================================
# apktool 可执行文件路径
ACE_APKTOOL_PATH=apktool

# Java 可执行文件路径
ACE_JAVA_PATH=java

# apksigner 可执行文件路径
ACE_APKSIGNER_PATH=apksigner

# 临时工作目录
ACE_WORK_DIR=/tmp/apk_crack_engine

# ============================================
# 签名配置 (密钥通过环境变量，禁止硬编码)
# ============================================
# 调试密钥库路径
ACE_KEYSTORE_PATH=/tmp/debug.keystore

# 密钥库密码 (通过环境变量传入，禁止写入代码)
ACE_KEYSTORE_PASSWORD=android

# 密钥别名
ACE_KEY_ALIAS=androiddebugkey

# 密钥密码 (通过环境变量传入)
ACE_KEY_PASSWORD=android

# ============================================
# 网络配置
# ============================================
# HTTP 请求默认超时 (秒)
ACE_HTTP_TIMEOUT=10

# HTTP 重试次数
ACE_HTTP_RETRIES=3

# 代理配置 (格式: http://host:port)
ACE_HTTP_PROXY=

# ============================================
# 授权服务器配置
# ============================================
# 授权服务器地址
ACE_LICENSE_SERVER_URL=http://localhost:8080

# 授权服务器端口
ACE_LICENSE_SERVER_PORT=8080

# 授权加密密钥 (通过环境变量传入，禁止硬编码)
ACE_LICENSE_SECRET_KEY=

# ============================================
# 破解引擎配置
# ============================================
# 最大重试次数
ACE_MAX_RETRIES=3

# 每轮超时时间 (秒)
ACE_TIMEOUT_PER_ROUND=300

# 成功率阈值
ACE_SUCCESS_THRESHOLD=0.8

# 自动修复环境
ACE_AUTO_FIX_ENV=true

# 并行批量破解模式
ACE_PARALLEL_MODE=false

# 最大并行工作者数
ACE_MAX_WORKERS=4

# ============================================
# 进化追踪配置
# ============================================
# 进化数据目录
ACE_EVO_DIR=~/.apk_crack_engine/evolution

# 触发进化的会话阈值
ACE_EVO_THRESHOLD=10
